<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.team2.activity.query.mapper.EmailLogQueryMapper">

    <resultMap id="emailLogResultMap" type="EmailLog">
        <id property="emailLogId" column="email_log_id"/>
        <result property="clientId" column="client_id"/>
        <result property="poId" column="po_id"/>
        <result property="emailTitle" column="email_title"/>
        <result property="emailRecipientName" column="email_recipient_name"/>
        <result property="emailRecipientEmail" column="email_recipient_email"/>
        <result property="emailSenderId" column="email_sender_id"/>
        <result property="emailStatus" column="email_status"
                typeHandler="com.team2.activity.query.mapper.typehandler.MailStatusTypeHandler"/>
        <result property="emailSentAt" column="email_sent_at"/>
        <result property="createdAt" column="created_at"/>
        <collection property="docTypes" ofType="EmailLogType"
                    resultMap="docTypeResultMap" columnPrefix="dt_"/>
        <collection property="attachments" ofType="EmailLogAttachment"
                    resultMap="attachmentResultMap" columnPrefix="at_"/>
    </resultMap>

    <resultMap id="docTypeResultMap" type="EmailLogType">
        <id property="emailLogTypeId" column="email_log_type_id"/>
        <result property="emailDocType" column="email_doc_type"
                typeHandler="com.team2.activity.query.mapper.typehandler.DocumentTypeHandler"/>
    </resultMap>

    <resultMap id="attachmentResultMap" type="EmailLogAttachment">
        <id property="emailLogAttachmentId" column="email_log_attachment_id"/>
        <result property="emailAttachmentFilename" column="email_attachment_filename"/>
        <result property="filePath" column="email_attachment_file_path"/>
    </resultMap>

    <sql id="emailLogColumns">
        e.email_log_id, e.client_id, e.po_id, e.email_title, e.email_recipient_name,
        e.email_recipient_email, e.email_sender_id, e.email_status, e.email_sent_at, e.created_at,
        dt.email_log_type_id AS dt_email_log_type_id, dt.email_doc_type AS dt_email_doc_type,
        at.email_log_attachment_id AS at_email_log_attachment_id, at.email_attachment_filename AS at_email_attachment_filename,
        at.email_attachment_file_path AS at_email_attachment_file_path
    </sql>

    <sql id="emailLogJoins">
        FROM email_logs e
        LEFT JOIN email_log_types dt ON e.email_log_id = dt.email_log_id
        LEFT JOIN email_log_attachments at ON e.email_log_id = at.email_log_id
    </sql>

    <select id="findEmailLogById" resultMap="emailLogResultMap">
        SELECT <include refid="emailLogColumns"/>
        <include refid="emailLogJoins"/>
        WHERE e.email_log_id = #{emailLogId}
    </select>

    <select id="findAllEmailLogs" resultMap="emailLogResultMap">
        SELECT <include refid="emailLogColumns"/>
        <include refid="emailLogJoins"/>
        ORDER BY e.created_at DESC
    </select>

    <select id="findEmailLogByClientId" resultMap="emailLogResultMap">
        SELECT <include refid="emailLogColumns"/>
        <include refid="emailLogJoins"/>
        WHERE e.client_id = #{clientId}
        ORDER BY e.created_at DESC
    </select>

    <select id="findEmailLogByEmailStatus" resultMap="emailLogResultMap">
        SELECT <include refid="emailLogColumns"/>
        <include refid="emailLogJoins"/>
        WHERE e.email_status = #{emailStatus}
        ORDER BY e.created_at DESC
    </select>

    <sql id="emailFilterConditions">
        <if test="clientId != null">
            AND client_id = #{clientId}
        </if>
        <if test="poId != null and poId != ''">
            AND po_id = #{poId}
        </if>
        <if test="emailStatus != null">
            AND email_status = #{emailStatus}
        </if>
        <if test="emailSenderId != null">
            AND email_sender_id = #{emailSenderId}
        </if>
        <if test="keyword != null and keyword != ''">
            AND (email_title LIKE CONCAT('%', #{keyword}, '%'))
        </if>
        <if test="dateFrom != null">
            AND email_sent_at &gt;= #{dateFrom}
        </if>
        <if test="dateTo != null">
            AND email_sent_at &lt;= #{dateTo}
        </if>
    </sql>

    <select id="findEmailLogsWithFilters" resultMap="emailLogResultMap">
        SELECT e.email_log_id, e.client_id, e.po_id, e.email_title, e.email_recipient_name,
               e.email_recipient_email, e.email_sender_id, e.email_status, e.email_sent_at, e.created_at,
               dt.email_log_type_id AS dt_email_log_type_id, dt.email_doc_type AS dt_email_doc_type,
               at.email_log_attachment_id AS at_email_log_attachment_id, at.email_attachment_filename AS at_email_attachment_filename,
               at.email_attachment_file_path AS at_email_attachment_file_path
        FROM (
            SELECT * FROM email_logs
            <where>
                <include refid="emailFilterConditions"/>
            </where>
            ORDER BY created_at DESC
            LIMIT #{limit} OFFSET #{offset}
        ) e
        LEFT JOIN email_log_types dt ON e.email_log_id = dt.email_log_id
        LEFT JOIN email_log_attachments at ON e.email_log_id = at.email_log_id
    </select>

    <select id="countEmailLogsWithFilters" resultType="long">
        SELECT COUNT(*)
        FROM email_logs e
        <where>
            <include refid="emailFilterConditions"/>
        </where>
    </select>

</mapper>
