<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.team2.activity.query.mapper.ActivityPackageQueryMapper">

    <resultMap id="activityPackageResultMap" type="ActivityPackage">
        <id property="packageId" column="package_id"/>
        <result property="packageTitle" column="package_title"/>
        <result property="packageDescription" column="package_description"/>
        <result property="poId" column="po_id"/>
        <result property="creatorId" column="creator_id"/>
        <result property="dateFrom" column="date_from"/>
        <result property="dateTo" column="date_to"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <collection property="viewers" ofType="ActivityPackageViewer"
                    resultMap="viewerResultMap" columnPrefix="v_"/>
        <collection property="items" ofType="ActivityPackageItem"
                    resultMap="itemResultMap" columnPrefix="i_"/>
    </resultMap>

    <resultMap id="viewerResultMap" type="ActivityPackageViewer">
        <id property="packageViewerId" column="package_viewer_id"/>
        <result property="userId" column="user_id"/>
    </resultMap>

    <resultMap id="itemResultMap" type="ActivityPackageItem">
        <id property="packageItemId" column="package_item_id"/>
        <result property="activityId" column="activity_id"/>
    </resultMap>

    <sql id="packageColumns">
        p.package_id, p.package_title, p.package_description,
        p.po_id, p.creator_id, p.date_from, p.date_to,
        p.created_at, p.updated_at,
        v.package_viewer_id AS v_package_viewer_id, v.user_id AS v_user_id,
        i.package_item_id AS i_package_item_id, i.activity_id AS i_activity_id
    </sql>

    <sql id="packageJoins">
        FROM activity_packages p
        LEFT JOIN activity_package_viewers v ON p.package_id = v.package_id
        LEFT JOIN activity_package_items i ON p.package_id = i.package_id
    </sql>

    <select id="findById" resultMap="activityPackageResultMap">
        SELECT <include refid="packageColumns"/>
        <include refid="packageJoins"/>
        WHERE p.package_id = #{packageId}
    </select>

    <select id="findAll" resultMap="activityPackageResultMap">
        SELECT <include refid="packageColumns"/>
        <include refid="packageJoins"/>
        ORDER BY p.created_at DESC
    </select>

    <select id="findAllByCreatorId" resultMap="activityPackageResultMap">
        SELECT <include refid="packageColumns"/>
        <include refid="packageJoins"/>
        WHERE p.creator_id = #{creatorId}
        ORDER BY p.created_at DESC
    </select>

    <select id="findAllByViewerUserId" resultMap="activityPackageResultMap">
        SELECT <include refid="packageColumns"/>
        <include refid="packageJoins"/>
        WHERE p.package_id IN (
            SELECT pv.package_id FROM activity_package_viewers pv WHERE pv.user_id = #{userId}
        )
        <if test="creatorId != null">
            AND p.creator_id = #{creatorId}
        </if>
        <if test="poId != null and poId != ''">
            AND p.po_id = #{poId}
        </if>
        ORDER BY p.created_at DESC
    </select>

</mapper>
